<section class="hero">
  <div class="container">
    <div class="hero-layout">

      <!-- Columna izquierda: texto -->
      <div class="hero-content">
        <span class="hero-eyebrow animate-on-scroll">DISEÑO &amp; DESARROLLO WEB</span>

        <h1 class="hero-title animate-on-scroll">
          Creamos la web<br />
          que tu negocio<br />
          <span class="flip-word gradient-text" id="flip-word">necesita</span>
        </h1>

        <p class="hero-subtitle animate-on-scroll">
          Webs profesionales y de alto rendimiento para que <strong class="highlight">te encuentren y te contacten</strong>.
          Soporte en 24hs y mantenimiento incluido. También reparamos y armamos tu PC.
        </p>

        <div class="hero-ctas animate-on-scroll">
          <a href="/presupuesto" class="btn btn-primary">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect width="18" height="18" x="3" y="3" rx="2"></rect>
              <path d="M7 7h10"></path>
              <path d="M7 12h10"></path>
              <path d="M7 17h10"></path>
            </svg>
            Solicitar presupuesto web
          </a>
          <a href="#servicios" class="btn btn-secondary">Ver todos los servicios</a>
        </div>
      </div>

      <!-- Columna derecha: visual -->
      <div class="hero-visual" aria-hidden="true">
        <div class="visual-card card-1">
          <div class="card-dot"></div>
          <div class="card-line"></div>
          <div class="card-line card-line--short"></div>
        </div>
        <div class="visual-card card-2">
          <div class="card-dot card-dot--accent"></div>
          <div class="card-line"></div>
          <div class="card-line card-line--short"></div>
        </div>
        <div class="visual-card card-3">
          <div class="card-dot"></div>
          <div class="card-line"></div>
          <div class="card-line card-line--mid"></div>
        </div>
        <div class="visual-badge">
          <span class="badge-pulse"></span>
          <span>Online 24hs</span>
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  const words = ['necesita', 'merece', 'busca', 'proyecta'];
  let index = 0;
  const wordEl = document.getElementById('flip-word') as HTMLElement | null;

  if (wordEl) {
    setInterval(() => {
      // Fase 1: fade out + sube levemente
      wordEl.style.opacity = '0';
      wordEl.style.transform = 'translateY(-6px)';

      setTimeout(() => {
        index = (index + 1) % words.length;
        wordEl.textContent = words[index];

        // Posicionar abajo sin transición
        wordEl.style.transition = 'none';
        wordEl.style.opacity = '0';
        wordEl.style.transform = 'translateY(8px)';

        // Fase 2: fade in + sube al lugar
        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            wordEl.style.transition = 'opacity 0.45s ease, transform 0.45s ease';
            wordEl.style.opacity = '1';
            wordEl.style.transform = 'translateY(0)';
          });
        });
      }, 350);
    }, 2800);
  }
</script>

<style>
  .hero {
    min-height: 100dvh;
    display: flex;
    align-items: center;
    position: relative;
    padding: 120px 0 80px;
    overflow: hidden;
  }

  /* Layout asimétrico: 55/45 */
  .hero-layout {
    display: grid;
    grid-template-columns: 55fr 45fr;
    gap: 64px;
    align-items: center;
    width: 100%;
  }

  .hero-content {
    position: relative;
    z-index: 2;
  }

  /* Eyebrow */
  .hero-eyebrow {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 2px;
    color: var(--accent);
    margin-bottom: 24px;
    animation-delay: 0.1s;
  }

  /* Título */
  .hero-title {
    font-size: clamp(44px, 5.5vw, 76px);
    font-weight: 800;
    line-height: 1.08;
    margin-bottom: 28px;
    letter-spacing: -0.03em;
    animation-delay: 0.2s;
  }

  /* Flip word */
  .flip-word {
    display: inline-block;
    transition: opacity 0.35s ease, transform 0.35s ease;
  }

  .gradient-text {
    background: linear-gradient(135deg, var(--accent) 0%, var(--accent-dim) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    display: inline-block;
  }

  /* Subtítulo */
  .hero-subtitle {
    font-size: clamp(16px, 1.8vw, 19px);
    color: var(--text-secondary);
    margin-bottom: 40px;
    max-width: 520px;
    font-weight: 300;
    line-height: 1.7;
    animation-delay: 0.3s;
  }

  .hero-subtitle .highlight {
    color: var(--text-primary);
    font-weight: 600;
  }

  /* Botones */
  .hero-ctas {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    animation-delay: 0.4s;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 15px 28px;
    border-radius: var(--radius-md);
    font-weight: 600;
    font-size: 15px;
    text-decoration: none;
    transition: all var(--transition);
    cursor: pointer;
    border: 1px solid transparent;
  }

  .btn-primary {
    background: var(--accent);
    color: var(--bg-primary);
  }

  .btn-primary:hover {
    background: var(--accent-dim);
    transform: translateY(-2px);
  }

  .btn-primary:active {
    transform: translateY(0) scale(0.98);
  }

  .btn-secondary {
    background: transparent;
    color: var(--text-primary);
    border-color: var(--border);
  }

  .btn-secondary:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  /* Visual derecho */
  .hero-visual {
    position: relative;
    height: 360px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .visual-card {
    position: absolute;
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 20px 24px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .card-1 {
    width: 200px;
    top: 20px;
    right: 20px;
    animation: float 6s ease-in-out infinite;
  }

  .card-2 {
    width: 180px;
    top: 130px;
    left: 10px;
    animation: float 7s ease-in-out infinite 1s;
  }

  .card-3 {
    width: 160px;
    bottom: 30px;
    right: 40px;
    animation: float 8s ease-in-out infinite 2s;
  }

  .card-dot {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: var(--border);
  }

  .card-dot--accent {
    background: rgba(45, 232, 144, 0.2);
    border: 1px solid var(--accent);
  }

  .card-line {
    height: 8px;
    background: var(--border);
    border-radius: 4px;
    width: 100%;
  }

  .card-line--short { width: 60%; }
  .card-line--mid  { width: 75%; }

  .visual-badge {
    position: absolute;
    bottom: 60px;
    left: 30px;
    display: flex;
    align-items: center;
    gap: 8px;
    background: var(--bg-tertiary);
    border: 1px solid var(--border-hover);
    border-radius: var(--radius-lg);
    padding: 8px 16px;
    font-size: 13px;
    font-family: var(--font-mono);
    color: var(--accent);
    animation: float 5s ease-in-out infinite 0.5s;
  }

  .badge-pulse {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--accent);
    animation: pulse 2s ease-in-out infinite;
    flex-shrink: 0;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50%       { transform: translateY(-12px); }
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.4; }
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .hero-layout {
      grid-template-columns: 1fr;
      gap: 48px;
    }

    .hero-visual {
      height: 220px;
    }
  }

  @media (max-width: 768px) {
    .hero {
      padding: 80px 0 60px;
    }

    .hero-visual {
      display: none;
    }

    .hero-ctas {
      flex-direction: column;
    }

    .btn {
      width: 100%;
      justify-content: center;
    }
  }
</style>
