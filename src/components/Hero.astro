---

---

<section class="hero">
  <div class="container">
    <div class="hero-layout">
      <!-- Columna izquierda: texto -->
      <div class="hero-content">
        <span class="hero-eyebrow animate-on-scroll"
          >DISEÑO WEB · SIN PLANTILLAS · A MEDIDA</span
        >

        <h1 class="hero-title animate-on-scroll">
          Desarrollo web<br />
          que tu negocio<br />
          <span class="flip-word gradient-text" id="flip-word">necesita</span>
        </h1>

        <p class="hero-subtitle animate-on-scroll">
          Webs profesionales y de alto rendimiento para que <strong
            class="highlight">te encuentren y te contacten</strong
          >. Diseño a medida, soporte en 24hs y mantenimiento incluido.
        </p>

        <div class="hero-ctas animate-on-scroll">
          <a href="/presupuesto" class="btn btn-primary">
            <svg
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <rect width="18" height="18" x="3" y="3" rx="2"></rect>
              <path d="M7 7h10"></path>
              <path d="M7 12h10"></path>
              <path d="M7 17h10"></path>
            </svg>
            Solicitar presupuesto web
          </a>
          <a href="#paquetes" class="btn btn-secondary"
            >Ver todos los servicios</a
          >
        </div>
      </div>

      <!-- Columna derecha: visual -->
      <div class="hero-visual" aria-hidden="true">
        <!-- Card principal: PageSpeed -->
        <div class="visual-card card-speed">
          <div class="speed-label">
            <svg
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              ><circle cx="12" cy="12" r="10"></circle><polyline
                points="12 6 12 12 16 14"></polyline></svg
            >
            PageSpeed
          </div>
          <div class="speed-score">98</div>
          <div class="speed-bar">
            <div class="speed-bar-fill"></div>
          </div>
          <div class="speed-sub">rendimiento / 100</div>
        </div>

        <!-- Card secundaria: Lighthouse audit -->
        <div class="visual-card card-lighthouse">
          <div class="lh-header">
            <svg
              width="12"
              height="12"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              ><circle cx="12" cy="12" r="10"></circle><path d="m9 12 2 2 4-4"
              ></path></svg
            >
            Lighthouse
          </div>
          <div class="lh-rows">
            <div class="lh-row">
              <span class="lh-label">Performance</span>
              <div class="lh-bar-wrap">
                <div class="lh-bar" style="width:98%"></div>
              </div>
              <span class="lh-val">98</span>
            </div>
            <div class="lh-row">
              <span class="lh-label">Accessibility</span>
              <div class="lh-bar-wrap">
                <div class="lh-bar" style="width:100%"></div>
              </div>
              <span class="lh-val">100</span>
            </div>
            <div class="lh-row">
              <span class="lh-label">SEO</span>
              <div class="lh-bar-wrap">
                <div class="lh-bar" style="width:95%"></div>
              </div>
              <span class="lh-val">95</span>
            </div>
            <div class="lh-row">
              <span class="lh-label">Best Practices</span>
              <div class="lh-bar-wrap">
                <div class="lh-bar" style="width:100%"></div>
              </div>
              <span class="lh-val">100</span>
            </div>
          </div>
        </div>

        <!-- Badge: entregas -->
        <div class="visual-badge">
          <span class="badge-pulse"></span>
          <span>Online 24hs</span>
        </div>

        <!-- Card terciaria: uptime -->
        <div class="visual-card card-uptime">
          <div class="uptime-row">
            <span class="uptime-dot"></span>
            <span class="uptime-text">Sitio activo</span>
          </div>
          <div class="uptime-bars">
            {
              Array.from({ length: 28 }).map((_, i) => (
                <span
                  class={`uptime-bar ${i === 5 || i === 12 ? "uptime-bar--low" : ""}`}
                />
              ))
            }
          </div>
          <div class="uptime-val">99.9% uptime</div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const words = ["necesita", "merece", "busca", "proyecta"];
  let index = 0;
  const wordEl = document.getElementById("flip-word") as HTMLElement | null;

  if (wordEl) {
    setInterval(() => {
      // Fase 1: fade out + sube levemente
      wordEl.style.opacity = "0";
      wordEl.style.transform = "translateY(-6px)";

      setTimeout(() => {
        index = (index + 1) % words.length;
        wordEl.textContent = words[index];

        // Posicionar abajo sin transición
        wordEl.style.transition = "none";
        wordEl.style.opacity = "0";
        wordEl.style.transform = "translateY(8px)";

        // Fase 2: fade in + sube al lugar
        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            wordEl.style.transition =
              "opacity 0.45s ease, transform 0.45s ease";
            wordEl.style.opacity = "1";
            wordEl.style.transform = "translateY(0)";
          });
        });
      }, 350);
    }, 2800);
  }
</script>

<style>
  .hero {
    min-height: 100dvh;
    display: flex;
    align-items: center;
    position: relative;
    padding: 120px 0 80px;
    overflow: hidden;
  }

  /* Layout asimétrico: 55/45 */
  .hero-layout {
    display: grid;
    grid-template-columns: 55fr 45fr;
    gap: 64px;
    align-items: center;
    width: 100%;
  }

  .hero-content {
    position: relative;
    z-index: 2;
  }

  /* Eyebrow */
  .hero-eyebrow {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 2px;
    color: var(--accent);
    margin-bottom: 24px;
    animation-delay: 0.1s;
  }

  /* Título */
  .hero-title {
    font-size: clamp(44px, 5.5vw, 76px);
    font-weight: 800;
    line-height: 1.08;
    margin-bottom: 28px;
    letter-spacing: -0.03em;
    animation-delay: 0.2s;
  }

  /* Flip word */
  .flip-word {
    display: inline-block;
    transition:
      opacity 0.35s ease,
      transform 0.35s ease;
  }

  .gradient-text {
    background: linear-gradient(
      135deg,
      var(--accent) 0%,
      var(--accent-dim) 100%
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    display: inline-block;
  }

  /* Subtítulo */
  .hero-subtitle {
    font-size: clamp(16px, 1.8vw, 19px);
    color: var(--text-secondary);
    margin-bottom: 40px;
    max-width: 520px;
    font-weight: 300;
    line-height: 1.7;
    animation-delay: 0.3s;
  }

  .hero-subtitle .highlight {
    color: var(--text-primary);
    font-weight: 600;
  }

  /* Botones */
  .hero-ctas {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    animation-delay: 0.4s;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 15px 28px;
    border-radius: var(--radius-md);
    font-weight: 600;
    font-size: 15px;
    text-decoration: none;
    transition: all var(--transition);
    cursor: pointer;
    border: 1px solid transparent;
  }

  .btn-primary {
    background: var(--accent);
    color: var(--bg-primary);
  }

  .btn-primary:hover {
    background: var(--accent-dim);
    transform: translateY(-2px);
  }

  .btn-primary:active {
    transform: translateY(0) scale(0.98);
  }

  .btn-secondary {
    background: transparent;
    color: var(--text-primary);
    border-color: var(--border);
  }

  .btn-secondary:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  /* Visual derecho */
  .hero-visual {
    position: relative;
    height: 380px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .visual-card {
    position: absolute;
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
  }

  /* Card PageSpeed */
  .card-speed {
    width: 200px;
    top: 10px;
    right: 16px;
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    animation: float 6s ease-in-out infinite;
  }

  .speed-label {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 11px;
    font-family: var(--font-mono);
    color: var(--text-muted);
    letter-spacing: 0.5px;
  }

  .speed-score {
    font-size: 52px;
    font-weight: 800;
    font-family: var(--font-mono);
    color: var(--accent);
    line-height: 1;
  }

  .speed-bar {
    height: 4px;
    background: var(--bg-tertiary);
    border-radius: 2px;
    overflow: hidden;
  }

  .speed-bar-fill {
    height: 100%;
    width: 98%;
    background: linear-gradient(90deg, var(--accent-dim), var(--accent));
    border-radius: 2px;
  }

  .speed-sub {
    font-size: 11px;
    color: var(--text-muted);
    font-family: var(--font-mono);
  }

  /* Card Lighthouse */
  .card-lighthouse {
    width: 210px;
    top: 140px;
    left: 0;
    padding: 16px 18px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    animation: float 7s ease-in-out infinite 1.2s;
  }

  .lh-header {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 11px;
    font-family: var(--font-mono);
    color: var(--text-muted);
    letter-spacing: 0.5px;
  }

  .lh-rows {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .lh-row {
    display: grid;
    grid-template-columns: 90px 1fr 28px;
    align-items: center;
    gap: 8px;
  }

  .lh-label {
    font-size: 10px;
    font-family: var(--font-mono);
    color: var(--text-muted);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .lh-bar-wrap {
    height: 4px;
    background: var(--bg-tertiary);
    border-radius: 2px;
    overflow: hidden;
  }

  .lh-bar {
    height: 100%;
    background: linear-gradient(90deg, var(--accent-dim), var(--accent));
    border-radius: 2px;
  }

  .lh-val {
    font-size: 11px;
    font-family: var(--font-mono);
    font-weight: 700;
    color: var(--accent);
    text-align: right;
  }

  /* Card uptime */
  .card-uptime {
    width: 195px;
    bottom: 20px;
    right: 28px;
    padding: 16px 18px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    animation: float 8s ease-in-out infinite 2s;
  }

  .uptime-row {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .uptime-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--accent);
    animation: pulse 2s ease-in-out infinite;
    flex-shrink: 0;
  }

  .uptime-text {
    font-size: 12px;
    font-family: var(--font-mono);
    color: var(--text-secondary);
  }

  .uptime-bars {
    display: flex;
    gap: 2px;
    align-items: flex-end;
    height: 24px;
  }

  .uptime-bar {
    flex: 1;
    height: 100%;
    background: rgba(45, 232, 144, 0.4);
    border-radius: 1px;
  }

  .uptime-bar--low {
    height: 35%;
    background: rgba(45, 232, 144, 0.15);
  }

  .uptime-val {
    font-size: 13px;
    font-weight: 700;
    font-family: var(--font-mono);
    color: var(--accent);
  }

  /* Badge Online */
  .visual-badge {
    position: absolute;
    top: 175px;
    right: 10px;
    display: flex;
    align-items: center;
    gap: 8px;
    background: var(--bg-tertiary);
    border: 1px solid var(--border-hover);
    border-radius: var(--radius-lg);
    padding: 8px 14px;
    font-size: 12px;
    font-family: var(--font-mono);
    color: var(--accent);
    animation: float 5s ease-in-out infinite 0.5s;
  }

  .badge-pulse {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--accent);
    animation: pulse 2s ease-in-out infinite;
    flex-shrink: 0;
  }

  @keyframes float {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-12px);
    }
  }

  @keyframes pulse {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0.4;
    }
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .hero-layout {
      grid-template-columns: 1fr;
      gap: 48px;
    }

    .hero-visual {
      height: 220px;
    }
  }

  @media (max-width: 768px) {
    .hero {
      padding: 80px 0 60px;
    }

    /* Gradiente ambiental que reemplaza el visual en mobile */
    .hero::after {
      content: "";
      position: absolute;
      top: -100px;
      right: -100px;
      width: 400px;
      height: 400px;
      background: radial-gradient(
        circle,
        rgba(45, 232, 144, 0.06) 0%,
        transparent 70%
      );
      pointer-events: none;
      z-index: 0;
    }

    .hero-visual {
      display: none;
    }

    .hero-ctas {
      flex-direction: column;
    }

    .btn {
      width: 100%;
      justify-content: center;
    }
  }
</style>
