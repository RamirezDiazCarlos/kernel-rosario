---
import Layout from "../layouts/Layout.astro";

const estilosOpciones = [
  "Minimalista", "Profesional", "Moderno", "Elegante",
  "Colorido", "Tecnológico", "Tradicional", "Juvenil",
  "Corporativo", "Creativo",
];

const seccionesOpciones = [
  "Inicio", "Quiénes somos", "Servicios", "Galería de fotos",
  "Portfolio", "Testimonios", "Blog / Noticias", "Preguntas frecuentes", "Contacto",
  "Catálogo de productos", "Carrito / Checkout",
];

const funcionesOpciones = [
  "Formulario de contacto", "Mapa interactivo", "Sistema de turnos / reservas",
  "Buscador interno", "Tienda online", "Blog / CMS", "Chat o WhatsApp flotante",
  "Pasarela de pagos", "Gestión de stock",
];
---

<Layout
  title="Presupuesto web — Kernel"
  description="Completá el formulario y recibís una propuesta personalizada en menos de 24 horas. Landing pages, sitios corporativos, tiendas online y más."
>
  <section class="presupuesto-section">
    <div class="container">
      <div class="presupuesto-inner">

        <header class="presupuesto-header">
          <a href="/" class="back-link">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <line x1="19" x2="5" y1="12" y2="12"></line>
              <polyline points="12 5 5 12 12 19"></polyline>
            </svg>
            Volver al inicio
          </a>
          <span class="section-tag">PRESUPUESTO</span>
          <h1 class="presupuesto-titulo">
            Contame sobre<br />
            <span class="gradient-text">tu proyecto</span>
          </h1>
          <p class="presupuesto-desc">
            Cuanto más detallado, mejor podemos preparar una propuesta visual adaptada a tu negocio. Respondemos en menos de 24 horas.
          </p>
        </header>

        <form id="form-presupuesto" class="presupuesto-form" novalidate>

          <!-- CONTACTO -->
          <div class="form-section">
            <div class="form-section-label">Contacto</div>
            <div class="form-grid">
              <div class="form-group">
                <label for="nombre">Nombre completo <span class="required">*</span></label>
                <input type="text" id="nombre" name="nombre" placeholder="Juan García" required autocomplete="name" />
              </div>
              <div class="form-group">
                <label for="email">Email <span class="required">*</span></label>
                <input type="email" id="email" name="email" placeholder="juan@ejemplo.com" required autocomplete="email" />
              </div>
              <div class="form-group">
                <label for="telefono">Teléfono <span class="optional">(opcional)</span></label>
                <input type="tel" id="telefono" name="telefono" placeholder="+54 9 341 000 0000" autocomplete="tel" />
              </div>
            </div>
          </div>

          <!-- SECCIÓN 1: IDENTIDAD -->
          <div class="form-section">
            <div class="form-section-label">1 — Tu proyecto</div>
            <div class="form-grid">

              <div class="form-group form-group--full">
                <label>Tipo de proyecto <span class="required">*</span></label>
                <div class="radio-group">
                  {["Landing page", "Sitio institucional / corporativo", "Tienda online", "Rediseño de sitio existente", "Otro"].map(op => (
                    <label class="radio-chip">
                      <input type="radio" name="tipo" value={op} required />
                      <span>{op}</span>
                    </label>
                  ))}
                </div>
              </div>

              <div class="form-group">
                <label for="marca">Nombre de tu marca o proyecto <span class="required">*</span></label>
                <input type="text" id="marca" name="marca" placeholder="Ej: Ferretería Don José" required />
              </div>

              <div class="form-group form-group--full">
                <label for="negocio">¿A qué se dedica tu negocio? <span class="required">*</span></label>
                <textarea id="negocio" name="negocio" rows="3" placeholder="Una descripción breve de lo que hacés y qué te diferencia de la competencia." required></textarea>
              </div>

              <div class="form-group form-group--full">
                <label>¿Tenés hosting contratado? <span class="optional">(opcional)</span></label>
                <div class="radio-group">
                  {["Sí, ya tengo hosting", "No, necesito ayuda con eso", "No sé qué es eso"].map(op => (
                    <label class="radio-chip">
                      <input type="radio" name="hosting" value={op} />
                      <span>{op}</span>
                    </label>
                  ))}
                </div>
              </div>

            </div>
          </div>

          <!-- SECCIÓN E-COMMERCE (visible solo si tipo = Tienda online) -->
          <div id="seccion-ecommerce" class="form-section" style="display:none">
            <div class="form-section-label">1b — Tu tienda online</div>
            <div class="form-grid">

              <div class="form-group form-group--full">
                <label>¿Cuántos productos aproximadamente vas a cargar? <span class="optional">(opcional)</span></label>
                <div class="radio-group">
                  {["Menos de 20", "Entre 20 y 100", "Más de 100", "No sé aún"].map(op => (
                    <label class="radio-chip">
                      <input type="radio" name="ecommerce_cantidad" value={op} />
                      <span>{op}</span>
                    </label>
                  ))}
                </div>
              </div>

              <div class="form-group form-group--full">
                <label>¿Los productos tienen variantes? <span class="optional">(opcional)</span></label>
                <div class="radio-group">
                  {["Sí (talles, colores, modelos...)", "No, cada producto es único"].map(op => (
                    <label class="radio-chip">
                      <input type="radio" name="ecommerce_variantes" value={op} />
                      <span>{op}</span>
                    </label>
                  ))}
                </div>
              </div>

              <div class="form-group form-group--full">
                <label>¿Qué medios de pago querés ofrecer? <span class="optional">(podés elegir varios)</span></label>
                <div class="chips-group">
                  {["MercadoPago", "Transferencia bancaria", "Tarjeta de crédito/débito", "Otro"].map(op => (
                    <label class="chip">
                      <input type="checkbox" name="ecommerce_pagos" value={op} />
                      <span>{op}</span>
                    </label>
                  ))}
                </div>
              </div>

              <div class="form-group form-group--full">
                <label>¿Hacés envíos? <span class="optional">(opcional)</span></label>
                <div class="radio-group">
                  {["Sí, con correo (Andreani, OCA, etc.)", "Sí, entrega propia o local", "No hago envíos"].map(op => (
                    <label class="radio-chip">
                      <input type="radio" name="ecommerce_envios" value={op} />
                      <span>{op}</span>
                    </label>
                  ))}
                </div>
              </div>

              <div class="form-group form-group--full">
                <label>¿El stock de productos cambia seguido? <span class="optional">(opcional)</span></label>
                <div class="radio-group">
                  {["Sí, agrego y quito productos frecuentemente", "No, los productos son siempre los mismos"].map(op => (
                    <label class="radio-chip">
                      <input type="radio" name="ecommerce_stock" value={op} />
                      <span>{op}</span>
                    </label>
                  ))}
                </div>
              </div>

            </div>
          </div>

          <!-- SECCIÓN 2: ESTÉTICA -->
          <div class="form-section">
            <div class="form-section-label">2 — Estética y branding</div>
            <div class="form-grid">

              <div class="form-group form-group--full">
                <label>¿Tenés logo o colores definidos? <span class="required">*</span></label>
                <div class="radio-group">
                  {[
                    "Sí, tengo logo y colores",
                    "Tengo logo pero sin paleta de colores",
                    "No tengo nada aún",
                  ].map(op => (
                    <label class="radio-chip">
                      <input type="radio" name="branding" value={op} required />
                      <span>{op}</span>
                    </label>
                  ))}
                </div>
              </div>

              <div class="form-group form-group--full" id="colores-field">
                <label for="colores">Describí tus colores o el estilo visual que tenés <span class="optional">(opcional)</span></label>
                <input type="text" id="colores" name="colores" placeholder="Ej: Azul marino y dorado, estilo elegante" />
              </div>

              <div class="form-group form-group--full">
                <label>¿Qué estilo buscás para el sitio? <span class="optional">(podés elegir varios)</span></label>
                <div class="chips-group">
                  {estilosOpciones.map(op => (
                    <label class="chip">
                      <input type="checkbox" name="estilos" value={op} />
                      <span>{op}</span>
                    </label>
                  ))}
                </div>
              </div>

              <div class="form-group form-group--full">
                <label for="referencias">Links de sitios web que te gusten <span class="optional">(opcional)</span></label>
                <textarea id="referencias" name="referencias" rows="3" placeholder={"Pegá los links y contame qué te gusta de cada uno:\nhttps://ejemplo.com → Me gusta la claridad y las animaciones suaves"}></textarea>
              </div>

            </div>
          </div>

          <!-- SECCIÓN 3: ESTRUCTURA -->
          <div class="form-section">
            <div class="form-section-label">3 — Estructura y contenido</div>
            <div class="form-grid">

              <div class="form-group form-group--full">
                <label>¿Qué secciones necesitás? <span class="optional">(podés elegir varias)</span></label>
                <div class="chips-group">
                  {seccionesOpciones.map(op => (
                    <label class="chip">
                      <input type="checkbox" name="secciones" value={op} />
                      <span>{op}</span>
                    </label>
                  ))}
                </div>
              </div>

              <div class="form-group form-group--full">
                <label>¿Cómo querés que te contacten tus clientes? <span class="optional">(podés elegir varios)</span></label>
                <div class="chips-group">
                  {["Por WhatsApp", "Por formulario de contacto", "Por email", "Con sistema de turnos/reservas"].map(op => (
                    <label class="chip">
                      <input type="checkbox" name="contactoClientes" value={op} />
                      <span>{op}</span>
                    </label>
                  ))}
                </div>
              </div>

              <div class="form-group form-group--full">
                <label>¿Cuál es el objetivo principal del sitio? <span class="required">*</span></label>
                <div class="radio-group">
                  {[
                    "Que me contacten por WhatsApp",
                    "Que reserven un turno",
                    "Mostrar mi portfolio / trabajos",
                    "Vender productos online",
                    "Informar / posicionarme como experto",
                    "Otro",
                  ].map(op => (
                    <label class="radio-chip">
                      <input type="radio" name="objetivo" value={op} required />
                      <span>{op}</span>
                    </label>
                  ))}
                </div>
              </div>

              <div class="form-group form-group--full">
                <label>¿Tenés fotos propias para el sitio?</label>
                <div class="radio-group">
                  {[
                    "Sí, tengo fotos propias",
                    "Prefiero imágenes de stock profesionales",
                    "Necesito una combinación de ambas",
                    "No sé aún",
                  ].map(op => (
                    <label class="radio-chip">
                      <input type="radio" name="fotos" value={op} />
                      <span>{op}</span>
                    </label>
                  ))}
                </div>
              </div>

            </div>
          </div>

          <!-- SECCIÓN 4: FUNCIONALIDADES -->
          <div class="form-section">
            <div class="form-section-label">4 — Funcionalidades</div>
            <div class="form-grid">

              <div class="form-group form-group--full">
                <label>¿Necesitás alguna función especial? <span class="optional">(podés elegir varias)</span></label>
                <div class="chips-group">
                  {funcionesOpciones.map(op => (
                    <label class="chip">
                      <input type="checkbox" name="funciones" value={op} />
                      <span>{op}</span>
                    </label>
                  ))}
                </div>
              </div>

              <div class="form-group form-group--full">
                <label>¿Necesitás poder editar el contenido vos mismo? <span class="required">*</span></label>
                <div class="radio-group">
                  {["Sí, quiero un panel para editar solo", "No, te aviso cuando necesite cambios", "No sé aún"].map(op => (
                    <label class="radio-chip">
                      <input type="radio" name="cms" value={op} required />
                      <span>{op}</span>
                    </label>
                  ))}
                </div>
              </div>

            </div>
          </div>

          <!-- SECCIÓN 5: PRESUPUESTO -->
          <div class="form-section">
            <div class="form-section-label">5 — Presupuesto y plazo</div>
            <div class="form-grid">

              <div class="form-group">
                <label for="presupuesto">Presupuesto estimado <span class="optional">(opcional)</span></label>
                <div class="select-wrapper">
                  <select id="presupuesto" name="presupuesto">
                    <option value="" disabled selected>Seleccioná un rango</option>
                    <option value="Menos de $200 USD">Menos de $200 USD</option>
                    <option value="$200 – $500 USD">$200 – $500 USD</option>
                    <option value="$500 – $1.000 USD">$500 – $1.000 USD</option>
                    <option value="Más de $1.000 USD">Más de $1.000 USD</option>
                    <option value="A definir">A definir / No sé aún</option>
                  </select>
                  <svg class="select-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <polyline points="6 9 12 15 18 9"></polyline>
                  </svg>
                </div>
              </div>

              <div class="form-group">
                <label for="plazo">Plazo deseado <span class="optional">(opcional)</span></label>
                <div class="select-wrapper">
                  <select id="plazo" name="plazo">
                    <option value="" disabled selected>Seleccioná un plazo</option>
                    <option value="Urgente (menos de 2 semanas)">Urgente (menos de 2 semanas)</option>
                    <option value="1 mes">1 mes</option>
                    <option value="2 – 3 meses">2 – 3 meses</option>
                    <option value="Sin apuro">Sin apuro</option>
                  </select>
                  <svg class="select-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <polyline points="6 9 12 15 18 9"></polyline>
                  </svg>
                </div>
              </div>

              <div class="form-group form-group--full">
                <label for="adicional">¿Algo más que quieras contarme? <span class="optional">(opcional)</span></label>
                <textarea id="adicional" name="adicional" rows="3" placeholder="Cualquier detalle extra que consideres importante."></textarea>
              </div>

            </div>
          </div>

          <div id="form-error" class="form-message form-message--error" hidden></div>

          <button type="submit" class="submit-btn" id="submit-btn">
            <span class="submit-text">Enviar consulta</span>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <line x1="5" x2="19" y1="12" y2="12"></line>
              <polyline points="12 5 19 12 12 19"></polyline>
            </svg>
          </button>

        </form>

      </div>
    </div>
  </section>

  <!-- Modal de éxito -->
  <div id="modal-success" class="modal-overlay" hidden aria-modal="true" role="dialog">
    <div class="modal-box">
      <div class="modal-icon" aria-hidden="true">
        <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <polyline points="20 6 9 17 4 12"></polyline>
        </svg>
      </div>
      <h2 class="modal-title">¡Consulta enviada!</h2>
      <p class="modal-desc">Te respondemos en menos de 24 horas con una propuesta personalizada.</p>
      <div class="modal-progress" aria-hidden="true">
        <div class="modal-progress-bar"></div>
      </div>
    </div>

      </div>
    </div>
  </section>
</Layout>

<script>
  // Mostrar/ocultar sección e-commerce y actualizar opciones de presupuesto según tipo de proyecto
  const tipoRadios = document.querySelectorAll<HTMLInputElement>('input[name="tipo"]');
  const seccionEcommerce = document.getElementById("seccion-ecommerce") as HTMLElement;
  const selectPresupuesto = document.getElementById("presupuesto") as HTMLSelectElement;

  const opcionesPresupuestoBase = [
    { value: "", label: "Seleccioná un rango", disabled: true },
    { value: "Menos de $200 USD", label: "Menos de $200 USD" },
    { value: "$200 – $500 USD", label: "$200 – $500 USD" },
    { value: "$500 – $1.000 USD", label: "$500 – $1.000 USD" },
    { value: "Más de $1.000 USD", label: "Más de $1.000 USD" },
    { value: "A definir", label: "A definir / No sé aún" },
  ];

  const opcionesPresupuestoEcommerce = [
    { value: "", label: "Seleccioná un rango", disabled: true },
    { value: "Menos de $600 USD", label: "Menos de $600 USD" },
    { value: "$600 – $1.000 USD", label: "$600 – $1.000 USD" },
    { value: "$1.000 – $2.000 USD", label: "$1.000 – $2.000 USD" },
    { value: "Más de $2.000 USD", label: "Más de $2.000 USD" },
    { value: "A definir", label: "A definir / No sé aún" },
  ];

  function setOpcionesPresupuesto(opciones: typeof opcionesPresupuestoBase) {
    selectPresupuesto.innerHTML = "";
    opciones.forEach(op => {
      const option = document.createElement("option");
      option.value = op.value;
      option.textContent = op.label;
      if (op.disabled) {
        option.disabled = true;
        option.selected = true;
      }
      selectPresupuesto.appendChild(option);
    });
  }

  tipoRadios.forEach(radio => {
    radio.addEventListener("change", () => {
      const esEcommerce = radio.value === "Tienda online";
      seccionEcommerce.style.display = esEcommerce ? "flex" : "none";
      setOpcionesPresupuesto(esEcommerce ? opcionesPresupuestoEcommerce : opcionesPresupuestoBase);
    });
  });

  // Mostrar/ocultar campo de colores según branding seleccionado
  const brandingRadios = document.querySelectorAll<HTMLInputElement>('input[name="branding"]');
  const coloresField = document.getElementById("colores-field") as HTMLElement;

  brandingRadios.forEach(radio => {
    radio.addEventListener("change", () => {
      const ocultar = radio.value === "No tengo nada aún";
      coloresField.style.display = ocultar ? "none" : "block";
    });
  });

  // Envío del formulario
  const form = document.getElementById("form-presupuesto") as HTMLFormElement;
  const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement;
  const submitText = submitBtn?.querySelector(".submit-text") as HTMLElement;
  const errorBox = document.getElementById("form-error") as HTMLElement;

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    errorBox.hidden = true;

    submitBtn.disabled = true;
    submitText.textContent = "Enviando...";

    try {
      const res = await fetch("/api/presupuesto", {
        method: "POST",
        body: new FormData(form),
      });

      const json = await res.json();

      if (!res.ok) {
        errorBox.textContent = json.error ?? "Ocurrió un error. Intentá de nuevo.";
        errorBox.hidden = false;
        submitBtn.disabled = false;
        submitText.textContent = "Enviar consulta";
        return;
      }

      const modal = document.getElementById("modal-success") as HTMLElement;
      modal.hidden = false;
      setTimeout(() => { window.location.href = "/"; }, 3000);
    } catch {
      errorBox.textContent = "Error de red. Verificá tu conexión e intentá de nuevo.";
      errorBox.hidden = false;
      submitBtn.disabled = false;
      submitText.textContent = "Enviar consulta";
    }
  });
</script>

<style>
  .presupuesto-section {
    min-height: 100vh;
    padding: 80px 0 120px;
  }

  .presupuesto-inner {
    max-width: 800px;
    margin: 0 auto;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: var(--text-muted);
    text-decoration: none;
    font-size: 14px;
    margin-bottom: 32px;
    transition: color var(--transition);
  }

  .back-link:hover { color: var(--accent); }

  .presupuesto-header {
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin-bottom: 56px;
  }

  .section-tag {
    display: inline-block;
    width: fit-content;
    padding: 8px 20px;
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 2px;
    color: var(--accent);
  }

  .presupuesto-titulo {
    font-size: clamp(40px, 6vw, 64px);
    font-weight: 800;
    line-height: 1.2;
    letter-spacing: -0.02em;
  }

  .gradient-text {
    background: linear-gradient(135deg, var(--accent) 0%, var(--accent-dim) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    display: inline-block;
  }

  .presupuesto-desc {
    font-size: 18px;
    color: var(--text-secondary);
    line-height: 1.7;
  }

  /* Form */
  .presupuesto-form {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  /* Secciones */
  .form-section {
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 32px;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .form-section-label {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 2px;
    color: var(--accent);
    text-transform: uppercase;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--border);
  }

  .form-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .form-group--full {
    grid-column: 1 / -1;
  }

  label {
    font-size: 14px;
    font-weight: 600;
    color: var(--text-secondary);
  }

  .required { color: var(--accent); }

  .optional {
    color: var(--text-muted);
    font-weight: 400;
    font-size: 12px;
  }

  input[type="text"],
  input[type="email"],
  input[type="tel"],
  textarea,
  select {
    width: 100%;
    background: var(--bg-tertiary);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 13px 16px;
    color: var(--text-primary);
    font-family: var(--font-display);
    font-size: 15px;
    transition: border-color var(--transition);
    outline: none;
    appearance: none;
  }

  input::placeholder,
  textarea::placeholder {
    color: var(--text-muted);
  }

  input:focus,
  textarea:focus,
  select:focus {
    border-color: var(--accent);
  }

  textarea {
    resize: vertical;
    min-height: 80px;
  }

  /* Select */
  .select-wrapper {
    position: relative;
  }

  .select-wrapper select {
    padding-right: 40px;
    cursor: pointer;
  }

  .select-icon {
    position: absolute;
    right: 14px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--text-muted);
    pointer-events: none;
  }

  /* Radio chips */
  .radio-group {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .radio-chip {
    cursor: pointer;
    font-weight: 400;
    color: var(--text-secondary);
  }

  .radio-chip input[type="radio"] {
    display: none;
  }

  .radio-chip span {
